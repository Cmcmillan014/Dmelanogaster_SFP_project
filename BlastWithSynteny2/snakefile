#yakuba
QUERY_GENOME = "data/NCBI/Dyak_data/GCF_016746365.2/GCF_016746365.2_Prin_Dyak_Tai18E2_2.1_genomic.fna"
QUERY_GTF    = "data/NCBI/Dyak_data/GCF_016746365.2/genomic_fixed.gtf"


SCRIPT = "BlastSynteny2"

OUTDIR = "results_export_geneious_yakuba_blast_results"

with open(GENE_LIST) as f:
    GENES = [line.strip() for line in f if line.strip()]

rule all:
    input:
        expand(f"{OUTDIR}/{{gene}}/synteny_plot.pdf", gene=GENES)

rule run_blast_synteny:
    output:
        pdf = f"{OUTDIR}/{{gene}}/synteny_plot.pdf"
    params:
        gene = "{gene}",
        outdir = f"{OUTDIR}/{{gene}}"
    conda:
        "envs/BlastSynteny2.yml"
    threads: 4
    log:
        f"{OUTDIR}/{{gene}}/run.log"
    shell:
        """
        mkdir -p {params.outdir}

        python3 {SCRIPT} \
            -r {REF_GENOME} \
            -g {REF_GTF} \
            -i {params.gene} \
            -y gene \
            -q {QUERY_GENOME} \
            -t {QUERY_GTF} \
            -o {params.outdir} \
            -m gene \
            -w 3 \
            --export_gff3_regions
        """
        # how to pipe std output to a file. 
        #put an example of my input in scratch on labshare. 